{% doc %}
  Renders a product card: image at the global card aspect ratio, serif caps
  title below, optional vendor and price (both hidden by default per the
  approved mockup — controlled by global theme settings).

  @param {product} product - The product to render
  @example
  {% render 'product-card', product: product %}
{% enddoc %}

<article class="product-card reveal">
  <a href="{{ product.url }}" class="product-card__link">
    <div class="product-card__media">
      {%- if product.featured_media -%}
        {{-
          product.featured_media
          | image_url: width: 900
          | image_tag:
            widths: '360, 540, 720, 900',
            sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 92vw',
            class: 'product-card__image',
            loading: 'lazy'
        -}}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <h3 class="product-card__title">{{ product.title }}</h3>

    {%- if settings.show_vendor and product.vendor != blank -%}
      <p class="product-card__vendor label">{{ product.vendor }}</p>
    {%- endif -%}

    {%- if settings.show_price -%}
      <p class="product-card__price">
        {%- if product.available -%}
          {%- if product.price_varies -%}
            {%- assign from_price = product.price_min | money -%}
            {{ 'products.from_price' | t: price: from_price }}
          {%- else -%}
            {{ product.price | money }}
          {%- endif -%}
        {%- else -%}
          {{ 'products.sold_out' | t }}
        {%- endif -%}
      </p>
    {%- endif -%}
  </a>
</article>
