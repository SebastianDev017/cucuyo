<section class="main-search page-padding section-spacing">
  <h1 class="main-search__title">{{ 'general.search.title' | t }}</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
    <label class="visually-hidden" for="SearchInput">{{ 'general.search.title' | t }}</label>
    <input
      id="SearchInput"
      class="field search-form__input"
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'general.search.placeholder' | t }}"
    >
    <button type="submit" class="button">{{ 'general.search.submit' | t }}</button>
  </form>

  {%- if search.performed -%}
    {%- paginate search.results by 12 -%}
      {%- if search.results.size > 0 -%}
        <p class="main-search__count label">
          {{ 'general.search.results_with_count' | t: count: search.results_count }}
        </p>
        <ul class="product-grid" role="list" style="--grid-columns: 3;">
          {%- for item in search.results -%}
            <li class="product-grid__item">
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- else -%}
                <a href="{{ item.url }}" class="search-result">
                  <p class="search-result__type label">{{ item.object_type }}</p>
                  <h3 class="search-result__title">{{ item.title }}</h3>
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p class="main-search__empty">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <div class="pagination-wrapper">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search page",
  "settings": []
}
{% endschema %}
