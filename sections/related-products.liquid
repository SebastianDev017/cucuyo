{%- liquid
  assign limit = section.settings.products_to_show
  assign min_size = limit | plus: 1
  assign source = product.collections.first
  if source == blank or source.products.size < min_size
    assign source = collections.all
  endif
  assign related = source.products | where: 'available', true
-%}

<section class="featured page-padding section-spacing">
  {%- if section.settings.heading != blank -%}
    <h2 class="featured__heading section-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if related.size > 0 -%}
    <ul class="product-grid" role="list" style="--grid-columns: {{ section.settings.columns }};">
      {%- assign shown = 0 -%}
      {%- for related_product in related -%}
        {%- unless related_product.id == product.id -%}
          {%- if shown < limit -%}
            <li class="product-grid__item">
              {% render 'product-card', product: related_product %}
            </li>
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    </ul>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Related products"
    }
  ]
}
{% endschema %}
